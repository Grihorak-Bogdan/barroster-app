# ── Required ───────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=django-insecure-change-me-in-production

# ── Database ───────────────────────────────────────────────────────────────────

# Leave unset to use SQLite (local development)
# DATABASE_URL=postgres://user:password@localhost:5432/barroster

# ── App ────────────────────────────────────────────────────────────────────────

DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── JWT ────────────────────────────────────────────────────────────────────────

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30

# ── Production (only needed when DEBUG=false) ──────────────────────────────────

# SECURE_SSL_REDIRECT=true
